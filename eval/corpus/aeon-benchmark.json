    {
      "id": "task-emul-0x650-0x660",
      "corpus_entry_id": "hello-aarch64",
      "kind": "extract_decrypted_strings",
      "prompt": "Emulate snippet 0x650-0x660",
      "expected_outcome": {
        "structured_claim": {
          "statement": "emulation trace produced",
          "required_evidence_kinds": ["emulation_trace"]
        }
      },
      "metadata": { "start_addr": "0x650", "end_addr": "0x660", "expected_registers": {} }
