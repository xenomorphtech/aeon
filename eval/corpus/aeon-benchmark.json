        "structured_claim": {
          "statement": "function skeleton",
          "required_evidence_kinds": ["json_artifact"]
        }
      },
      "metadata": { "addr": "0x788" }
    },
    {
      "id": "task-datalog-cfg-0x650",
      "corpus_entry_id": "hello-aarch64",
      "kind": "produce_evidence_bundle",
      "prompt": "Run CFG edges query on 0x650",
      "expected_outcome": {
        "structured_claim": {
          "statement": "datalog query result",
          "required_evidence_kinds": ["datalog_result"]
        }
      },
      "metadata": { "addr": "0x650", "query": "reachability" }
    },
    {
      "id": "task-datalog-cfg-0x710",
      "corpus_entry_id": "hello-aarch64",
