{
  "id": "aeon-benchmark-v1",
  "description": "Core aeon capability benchmark using the sample ARM64 ELF.",
  "binaries": [
    {
      "id": "hello-aarch64",
      "path": "samples/hello_aarch64.elf",
      "architecture": "aarch64",
      "format": "elf",
      "description": "Sample ARM64 ELF for testing",
      "tags": ["sample"]
    }
  ],
  "tasks": [
    {
      "id": "task-skeleton-0x650",
      "corpus_entry_id": "hello-aarch64",
      "kind": "classify_behavior",
      "prompt": "Classify function at 0x650",
      "expected_outcome": {
        "structured_claim": {
          "statement": "function skeleton",
          "required_evidence_kinds": ["json_artifact"]
        }
      },
      "metadata": { "addr": "0x650" }
    },
    {
      "id": "task-skeleton-0x710",
      "corpus_entry_id": "hello-aarch64",
      "kind": "classify_behavior",
      "prompt": "Classify function at 0x710",
